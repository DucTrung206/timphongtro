  <diagram id="9PwEb0fy8kg3ROwxzpIc" name="Trang-2">
    <mxGraphModel dx="1088" dy="647" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="IaxPzrqxGMI7nUzvBSXq-1" parent="1" style="text;whiteSpace=wrap;" value="🌐 TRANG CHỦ &amp; GIAO DIỆN CHÍNH (Dựa trên UI Xăng Gần Đây)&#xa; ├── 🔍 Header &amp; Tìm kiếm&#xa; │    ├── Thanh tìm kiếm địa điểm/khu vực&#xa; │    ├── Nút &quot;Định vị vị trí của tôi&quot; (Sử dụng Maps API)&#xa; │    └── Nút Đăng nhập/Đăng ký&#xa; ├── 🏠 Vùng Banner &amp; Khuyến nghị&#xa; │    ├── Thông điệp &quot;Tìm phòng trọ gần nhất ngay&quot;&#xa; │    └── Thẻ hiển thị nhanh phòng trọ gần/phù hợp nhất&#xa; ├── 🗺️ Khu vực Bản đồ &amp; Danh sách kết quả&#xa; │    ├── Bản đồ tương tác (Hiển thị icon &quot;Ngôi nhà&quot; tại vị trí có trọ)&#xa; │    ├── Danh sách thẻ phòng trọ (Card UI)&#xa; │    │    ├── Trạng thái: Còn phòng (Xanh) / Hết phòng (Đỏ)&#xa; │    │    ├── Thông tin cơ bản: Giá, Diện tích, Khoảng cách&#xa; │    │    ├── Nút &quot;Chỉ đường&quot; (Mở route trên Google Maps)&#xa; │    │    └── Nút &quot;Thả tim / Lưu tin&quot; (Dành cho người tìm trọ)&#xa; │    └── 🎛️ Bộ lọc nâng cao: &#xa; │         └── Giá/tháng, Khoảng cách, Diện tích, Loại phòng, Tiện ích&#xa; └── 🔽 Footer (Chân trang)&#xa;      ├── Logo &amp; Cột thông tin giới thiệu ngắn&#xa;      ├── Cột Liên hệ (+84..., Email, Địa chỉ)&#xa;      └── Dòng Bản quyền &amp; Thiết kế bởi... (Không có phần Danh mục &amp; Hỗ trợ)&#xa;&#xa;&#xa;🔐 LUỒNG XÁC THỰC (AUTHENTICATION)&#xa; └── 🎭 Màn hình Chọn Vai Trò (Bắt buộc chọn 1 trước khi đi tiếp)&#xa;      ├── 👤 Tùy chọn 1: Người đăng bài (Chủ trọ)&#xa;      └── 👤 Tùy chọn 2: Người tìm phòng (Khách thuê)&#xa;      ├── 🔑 Đăng nhập&#xa;      │    ├── Nhập Username/Email &amp; Password&#xa;      │    ├── Cảnh báo sai thông tin (Yêu cầu nhập lại)&#xa;      │    └── Quên mật khẩu (Khôi phục qua Email)&#xa;      └── 📝 Đăng ký&#xa;           └── Điền form: Tên đăng nhập, Tên người dùng, Email, Mật khẩu, Nhập lại Mật khẩu&#xa;&#xa;&#xa;🛠️ MENU TÍNH NĂNG THEO VAI TRÒ&#xa; ├── 🏢 1. NGƯỜI ĐĂNG BÀI (CHỦ TRỌ) - [Menu Sidebar / Hamburger Icon góc trái]&#xa; │    ├── 📝 Quản lý Tin đăng (Đăng bài mới / Sửa tin)&#xa; │    │    ├── Tải ảnh lên&#xa; │    │    ├── Thông tin liên hệ: Tên chủ trọ, SĐT, Địa chỉ&#xa; │    │    ├── Thông tin phòng: Giá/tháng, Diện tích (m²), Tiền cọc, Sức chứa&#xa; │    │    ├── Phân loại: Loại phòng (Trọ SV, CC mini, Nguyên căn)&#xa; │    │    ├── Tiện ích (Checkbox): Điều hòa, Nóng lạnh, Chỗ để xe, Máy giặt, Chung/Không chung chủ&#xa; │    │    └── Thời gian: Giờ làm việc, Giờ giấc ra vào, Giờ hỗ trợ xem phòng&#xa; │    ├── 🔄 Cập nhật trạng thái&#xa; │    │    └── Chuyển đổi: Còn phòng (Xanh) &lt;-&gt; Đã hết (Đỏ)&#xa; │    └── 💬 Hộp thư Chat (Nhắn tin với người tìm trọ)&#xa; │&#xa; ├── 🔎 2. NGƯỜI TÌM PHÒNG&#xa; │    ├── 🎛️ Tìm kiếm &amp; Bộ lọc (Như phần Trang chủ)&#xa; │    ├── ❤️ Quản lý Tin đã lưu (Xem lại các phòng đã Thả tim)&#xa; │    ├── 💬 Hộp thư Chat (Nhắn tin với chủ trọ)&#xa; │    └── ⚖️ Đánh giá &amp; Báo cáo&#xa; │         ├── Đánh giá sao &amp; Review chủ trọ (Sau khi thuê)&#xa; │         └── Report (Báo cáo tin giả / lừa đảo cọc)&#xa; │&#xa; └── 🛡️ 3. QUẢN TRỊ VIÊN (ADMIN DASHBOARD) - Hệ thống ngầm&#xa;      ├── 📋 Kiểm duyệt nội dung (Duyệt bài đăng của Chủ trọ trước khi hiện lên Bản đồ)&#xa;      ├── 🚨 Xử lý Báo cáo (Xem xét các report từ người tìm phòng để gỡ bài/khóa tài khoản)&#xa;      └── 👥 Quản lý Người dùng (Danh sách Chủ trọ &amp; Người tìm phòng)" vertex="1">
          <mxGeometry height="1090" width="800" x="170" y="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
